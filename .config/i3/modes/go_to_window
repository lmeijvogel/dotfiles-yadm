mode "$go_to_mode" {
      bindsym e $exec /usr/bin/microsoft-edge ; mode "default"
      bindsym s $exec i3-msg [class=Slack] focus ; mode "default"
      bindsym t $exec $HOME/bin/start-teams lfx ; mode "default"
      bindsym r $exec simplescreenrecorder ; mode "default"
      bindsym w mode "$webcam_mode"
      bindsym m mode "$work_mode"

      # back to normal: Enter or Escape
      bindsym Return mode "default"
      bindsym Escape mode "default"
}
